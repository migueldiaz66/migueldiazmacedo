---
import { getCollection } from 'astro:content';
import Article from '../../layouts/Article.astro';

export async function getStaticPaths() {
  const entries = await getCollection('bibliometria', (e) => !e.data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const path = `/bibliometria/${entry.slug}/`;
---
<Article
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  updatedDate={entry.data.updatedDate}
  topicSlug="bibliometria"
  path={path}
  image={entry.data.cover}
  seoTitle={entry.data.seoTitle}
  faq={entry.data.faq}
  entities={entry.data.entities}
  tags={entry.data.tags}
  citations={entry.data.citations}
  citationsNote={entry.data.citationsNote}
  glossary={entry.data.glossary}
>
  <Content />
</Article>
