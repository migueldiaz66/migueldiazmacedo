---
/* Ruta de PRUEBAS para borradores. Renderiza cualquier artículo fiscal
   —incluidos los draft: true— en /fiscal/borrador/<slug>/. No está enlazada;
   sirve para iterar en el dev de Astro. Se elimina al publicar. */
import { getCollection } from 'astro:content';
import Article from '../../../layouts/Article.astro';

export async function getStaticPaths() {
  // Solo borradores que son artículos del blog para revisión —no los derivados
  // (académico, LinkedIn, que empiezan con 'cfdi-evolucion'). Hoy: el panorama.
  const entries = await getCollection(
    'fiscal',
    (e) => e.data.draft && !e.slug.startsWith('cfdi-evolucion')
  );
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const path = `/fiscal/borrador/${entry.slug}/`;
---
<Article
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  updatedDate={entry.data.updatedDate}
  topicSlug="fiscal"
  path={path}
  image={entry.data.cover}
  seoTitle={entry.data.seoTitle}
  faq={entry.data.faq}
  noindex={true}
  entities={entry.data.entities}
  tags={entry.data.tags}
  citations={entry.data.citations}
  citationsNote={entry.data.citationsNote}
  glossary={entry.data.glossary}
>
  <Content />
</Article>
