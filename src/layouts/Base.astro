---
import '../styles/global.css';
import { publishedTopics } from '../config/topics';

export interface Props {
  title: string;
  description: string;
  accent?: string;
  /* canonical path, e.g. "/fiscal/cfdi-evolucion/" */
  path?: string;
  /* 'article' for blog posts; defaults to 'website' */
  type?: 'website' | 'article';
  /* optional social/share image (path under /public or absolute URL) */
  image?: string;
  /* article dates, used for og:article meta and structured data */
  pubDate?: Date;
  updatedDate?: Date;
  /* when true, emit robots noindex (for draft previews) */
  noindex?: boolean;
  /* schema.org `about` nodes (knowledge-graph entities) for articles */
  about?: { '@type': string; name: string; sameAs: string[] }[];
  /* comma-separated keywords and the article's section/category */
  keywords?: string;
  articleSection?: string;
  /* schema.org `citation` nodes (works cited by the article) */
  citation?: { '@type': string; name: string; url?: string | string[] }[];
}

const { title, description, accent, path = '', type = 'website', image, pubDate, updatedDate, noindex = false, about, keywords, articleSection, citation } = Astro.props;
const topics = publishedTopics();
const site = 'https://migueldiazmacedo.com';
const canonical = site + path;
const author = 'Miguel Díaz Macedo';
// Lightweight reference to the full Person entity defined on /acerca/.
const authorRef = { '@type': 'Person', name: author, url: site + '/acerca/' };
const ogTitle = title.replace(/ — migueldiazmacedo$/, '');
const ogImage = image ? new URL(image, site).href : undefined;

const jsonLd = type === 'article'
  ? {
      '@context': 'https://schema.org',
      // Doble tipo: Article (tipo amplio que reconocen buscadores y parsers) +
      // TechArticle (subtipo más preciso para contenido técnico).
      '@type': ['Article', 'TechArticle'],
      headline: ogTitle,
      description,
      url: canonical,
      mainEntityOfPage: canonical,
      ...(ogImage ? { image: ogImage } : {}),
      ...(pubDate ? { datePublished: pubDate.toISOString() } : {}),
      ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
      ...(about && about.length ? { about } : {}),
      ...(keywords ? { keywords } : {}),
      ...(articleSection ? { articleSection } : {}),
      ...(citation && citation.length ? { citation } : {}),
      author: authorRef,
      publisher: authorRef,
      inLanguage: 'es',
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'migueldiazmacedo',
      url: site,
      inLanguage: 'es',
      author: authorRef,
    };
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google Analytics (GA4) — carga en todas las páginas vía este layout -->
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-QCBEYRSRJM"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QCBEYRSRJM');
    </script>

    <!-- Microsoft Clarity -->
    <script is:inline type="text/javascript">
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "xcpnp74rwa");
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="migueldiazmacedo" />
    <meta property="og:locale" content="es_MX" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {type === 'article' && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {type === 'article' && updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fonts: humanist sans for reading, mono for the data layer -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;650&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {accent && <style set:html={`:root{--accent:${accent}}`} />}
  </head>
  <body>
    <a class="skip" href="#main">Saltar al contenido</a>

    <header class="site-head">
      <div class="wrap head-inner">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true"></span>
          migueldiazmacedo
        </a>
        <nav aria-label="Navegación">
          <ul>
            {topics.map((t) => (
              <li>
                <a href={`/${t.slug}/`}>{t.label}</a>
              </li>
            ))}
            <li><a href="/glosario/">Glosario</a></li>
            <li><a href="/acerca/">Acerca</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap foot-inner">
        <div class="chain solid" aria-hidden="true">
          <span class="node hollow"></span>
          <span class="seg"></span>
          <span class="node"></span>
          <span class="seg"></span>
          <span class="node hollow"></span>
        </div>
        <p class="small muted">
          © {new Date().getFullYear()} Miguel Díaz Macedo · Ciudad de México
        </p>
      </div>
    </footer>

    <style>
      .skip {
        position: absolute;
        left: -999px;
        top: 0;
        background: var(--ink);
        color: var(--paper);
        padding: 0.6rem 1rem;
        z-index: 10;
      }
      .skip:focus { left: 0.5rem; top: 0.5rem; }

      .site-head {
        border-bottom: 1px solid var(--line);
        background: color-mix(in srgb, var(--paper) 88%, white);
        position: sticky;
        top: 0;
        backdrop-filter: saturate(1.1) blur(6px);
        z-index: 5;
      }
      .head-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        min-height: 64px;
        flex-wrap: wrap;
      }
      .brand {
        font-family: var(--mono);
        font-weight: 500;
        font-size: var(--step-0);
        color: var(--ink);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.7ch;
        letter-spacing: -0.02em;
      }
      .brand-mark {
        width: 11px; height: 11px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 0 3px var(--seal-dim);
      }
      nav ul {
        display: flex;
        gap: 1.4rem;
        list-style: none;
        margin: 0; padding: 0;
        flex-wrap: wrap;
      }
      nav a {
        font-family: var(--mono);
        font-size: var(--step--1);
        color: var(--muted);
        text-decoration: none;
        padding: 0.2rem 0;
        border-bottom: 2px solid transparent;
      }
      nav a:hover { color: var(--ink); border-bottom-color: var(--accent); }

      .site-foot {
        border-top: 1px solid var(--line);
        margin-top: 5rem;
        padding: 2.5rem 0 3.5rem;
      }
      .foot-inner { display: grid; gap: 1.2rem; }
      .foot-inner .chain { max-width: 220px; }
    </style>
  </body>
</html>
