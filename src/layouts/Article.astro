---
import Base from './Base.astro';
import { topicBySlug } from '../config/topics';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  topicSlug: string;
  path: string;
  image?: string;
  seoTitle?: string;
  faq?: { q: string; a: string }[];
  noindex?: boolean;
}

const { title, description, pubDate, updatedDate, topicSlug, path, image, seoTitle, faq, noindex } = Astro.props;
const topic = topicBySlug(topicSlug);
const accent = topic?.accent;

// <title>: short SEO title if given (kept <70), else the full title + brand.
const headTitle = seoTitle ?? `${title} — migueldiazmacedo`;

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('es-MX', {
    year: 'numeric', month: 'long', day: 'numeric',
    hour: '2-digit', minute: '2-digit', hour12: false,
    timeZone: 'America/Mexico_City',
  }).format(d);
---
<Base
  title={headTitle}
  description={description}
  accent={accent}
  path={path}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  image={image}
  noindex={noindex}
>
  <article class="wrap prose article">
    <p class="eyebrow">
      <a href={`/${topicSlug}/`} style="color:inherit;text-decoration:none">{topic?.label}</a>
    </p>
    <h1>{title}</h1>
    <p class="lede muted">{description}</p>
    <p class="meta small mono muted">
      {fmt(pubDate)}{updatedDate ? ` · act. ${fmt(updatedDate)}` : ''}
    </p>

    <div class="chain" aria-hidden="true" style="margin:1.8rem 0 2.6rem;max-width:340px">
      <span class="node"></span><span class="seg"></span>
      <span class="node hollow"></span><span class="seg"></span>
      <span class="node"></span>
    </div>

    <div class="body">
      <slot />
    </div>

    {faq && faq.length > 0 && (
      <section class="faq" aria-labelledby="faq-h">
        <h2 id="faq-h">Preguntas frecuentes</h2>
        {faq.map((item) => (
          <div class="faq-item">
            <h3 class="faq-q">{item.q}</h3>
            <p class="faq-a">{item.a}</p>
          </div>
        ))}
      </section>
    )}
    {faq && faq.length > 0 && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: faq.map((item) => ({
            '@type': 'Question',
            name: item.q,
            acceptedAnswer: { '@type': 'Answer', text: item.a },
          })),
        })}
      />
    )}

    <hr class="divider" />
    <p class="small muted">
      <a href={`/${topicSlug}/`}>← Volver a {topic?.label}</a>
    </p>
  </article>

  <style>
    .article { padding-top: 3.5rem; }
    .lede {
      font-size: var(--step-1);
      line-height: 1.45;
      margin: 0.2em 0 1em;
    }
    .meta { margin: 0; }

    /* reading body */
    .body :global(p) { margin: 1.15em 0; }
    .body :global(h2) {
      padding-top: 0.4em;
      border-top: 1px solid var(--line);
    }
    .body :global(ul),
    .body :global(ol) { padding-left: 1.3em; }
    .body :global(li) { margin: 0.4em 0; }
    .body :global(strong) { font-weight: 650; }
    .body :global(code) {
      font-family: var(--mono);
      font-size: 0.9em;
      background: var(--seal-dim);
      padding: 0.1em 0.4em;
      border-radius: 3px;
    }
    .body :global(blockquote) {
      margin: 1.4em 0;
      padding: 0.2em 0 0.2em 1.2em;
      border-left: 3px solid var(--accent);
      color: var(--muted);
    }
    /* tables — important for the complementos matrices */
    .body :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 1.6em 0;
      font-size: var(--step--1);
    }
    .body :global(th),
    .body :global(td) {
      text-align: left;
      padding: 0.55em 0.7em;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
    }
    .body :global(th) {
      font-family: var(--mono);
      font-weight: 500;
      font-size: 0.85em;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      color: var(--muted);
    }
    .body :global(table) { display: block; overflow-x: auto; }

    /* references section reads as data */
    .body :global(hr) {
      border: 0;
      border-top: 1px solid var(--line);
      margin: 2.5em 0;
    }

    /* FAQ — atomic Q&A, citable by AI and search */
    .faq { margin-top: 3.5rem; }
    .faq > h2 { padding-top: 0.4em; border-top: 1px solid var(--line); }
    .faq-item { border-top: 1px solid var(--line); }
    .faq-item:first-of-type { border-top: 0; }
    .faq-q { font-size: var(--step-1); margin: 1.4em 0 0.3em; }
    .faq-a { margin: 0 0 1.4em; }
  </style>
</Base>
