---
import Base from './Base.astro';
import { topicBySlug } from '../config/topics';
import { resolveEntities } from '../config/entities';
import { glossaryByKeys } from '../config/glossary';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  topicSlug: string;
  path: string;
  image?: string;
  seoTitle?: string;
  faq?: { q: string; a: string }[];
  noindex?: boolean;
  entities?: string[];
  tags?: string[];
  citations?: { text: string; urls: string[] }[];
  citationsNote?: string;
  glossary?: string[];
}

const { title, description, pubDate, updatedDate, topicSlug, path, image, seoTitle, faq, noindex, entities, tags, citations, citationsNote, glossary } = Astro.props;
const topic = topicBySlug(topicSlug);
const accent = topic?.accent;
const about = resolveEntities(entities);
const keywords = tags && tags.length ? tags.join(', ') : undefined;
// Glosario contextual del artículo (subconjunto del catálogo), orden alfabético.
const glossaryTerms = glossaryByKeys(glossary ?? []).sort((a, b) =>
  (a.abbr ?? a.name).localeCompare(b.abbr ?? b.name, 'es', { sensitivity: 'base' })
);
// Mismo arreglo de referencias -> nodos schema.org `citation`.
const citation = (citations ?? []).map((c) => ({
  '@type': 'CreativeWork',
  name: c.text,
  ...(c.urls && c.urls.length ? { url: c.urls.length === 1 ? c.urls[0] : c.urls } : {}),
}));

// <title>: short SEO title if given (kept <70), else the full title + brand.
const headTitle = seoTitle ?? `${title} — migueldiazmacedo`;

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('es-MX', {
    year: 'numeric', month: 'long', day: 'numeric',
    hour: '2-digit', minute: '2-digit', hour12: false,
    timeZone: 'America/Mexico_City',
  }).format(d);
---
<Base
  title={headTitle}
  description={description}
  accent={accent}
  path={path}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  image={image}
  noindex={noindex}
  about={about}
  keywords={keywords}
  articleSection={topic?.label}
  citation={citation}
>
  <article class="wrap prose article">
    <p class="eyebrow">
      <a href={`/${topicSlug}/`} style="color:inherit;text-decoration:none">{topic?.label}</a>
    </p>
    <h1>{title}</h1>
    <p class="lede muted">{description}</p>
    <p class="meta small mono muted">
      {fmt(pubDate)}{updatedDate ? ` · act. ${fmt(updatedDate)}` : ''}
    </p>

    <div class="chain" aria-hidden="true" style="margin:1.8rem 0 2.6rem;max-width:340px">
      <span class="node"></span><span class="seg"></span>
      <span class="node hollow"></span><span class="seg"></span>
      <span class="node"></span>
    </div>

    <div class="body">
      <slot />
    </div>

    {citations && citations.length > 0 && (
      <section class="refs" aria-labelledby="refs-h">
        <h2 id="refs-h">Referencias</h2>
        {citations.map((c, i) => (
          <p class="ref" id={`ref-${i + 1}`}>
            <span class="ref-n mono">[{i + 1}]</span> {c.text}
            {c.urls && c.urls.map((u) => (
              <>{' '}<a class="ref-url" href={u} rel="external nofollow">{u}</a></>
            ))}
          </p>
        ))}
        {citationsNote && (
          <p class="ref-note small muted"><em>{citationsNote}</em></p>
        )}
      </section>
    )}

    {glossaryTerms.length > 0 && (
      <section class="article-glossary" aria-labelledby="gloss-h">
        <h2 id="gloss-h">Glosario</h2>
        <dl class="g-terms">
          {glossaryTerms.map((t) => (
            <div class="g-term" id={`gloss-${t.key}`}>
              <dt>
                <span class="g-head">{t.abbr ?? t.name}</span>
                {t.abbr && <span class="g-name mono muted">{t.name}</span>}
              </dt>
              <dd>{t.definition}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}
    {glossaryTerms.length > 0 && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'DefinedTermSet',
          name: `Glosario — ${title}`,
          inLanguage: 'es',
          hasDefinedTerm: glossaryTerms.map((t) => ({
            '@type': 'DefinedTerm',
            name: t.abbr ? `${t.name} (${t.abbr})` : t.name,
            ...(t.abbr ? { termCode: t.abbr } : {}),
            description: t.definition,
            ...(t.sameAs ? { sameAs: t.sameAs } : {}),
          })),
        })}
      />
    )}

    {faq && faq.length > 0 && (
      <section class="faq" aria-labelledby="faq-h">
        <h2 id="faq-h">Preguntas frecuentes</h2>
        {faq.map((item) => (
          <div class="faq-item">
            <h3 class="faq-q">{item.q}</h3>
            <p class="faq-a">{item.a}</p>
          </div>
        ))}
      </section>
    )}
    {faq && faq.length > 0 && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: faq.map((item) => ({
            '@type': 'Question',
            name: item.q,
            acceptedAnswer: { '@type': 'Answer', text: item.a },
          })),
        })}
      />
    )}

    <hr class="divider" />
    <p class="small muted">
      <a href={`/${topicSlug}/`}>← Volver a {topic?.label}</a>
    </p>
  </article>

  <style>
    .article { padding-top: 3.5rem; }
    .lede {
      font-size: var(--step-1);
      line-height: 1.45;
      margin: 0.2em 0 1em;
    }
    .meta { margin: 0; }

    /* reading body */
    .body :global(p) { margin: 1.15em 0; }
    .body :global(h2) {
      padding-top: 0.4em;
      border-top: 1px solid var(--line);
    }
    .body :global(ul),
    .body :global(ol) { padding-left: 1.3em; }
    .body :global(li) { margin: 0.4em 0; }
    .body :global(strong) { font-weight: 650; }
    .body :global(code) {
      font-family: var(--mono);
      font-size: 0.9em;
      background: var(--seal-dim);
      padding: 0.1em 0.4em;
      border-radius: 3px;
    }
    .body :global(blockquote) {
      margin: 1.4em 0;
      padding: 0.2em 0 0.2em 1.2em;
      border-left: 3px solid var(--accent);
      color: var(--muted);
    }
    /* tables — important for the complementos matrices */
    .body :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 1.6em 0;
      font-size: var(--step--1);
    }
    .body :global(th),
    .body :global(td) {
      text-align: left;
      padding: 0.55em 0.7em;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
    }
    .body :global(th) {
      font-family: var(--mono);
      font-weight: 500;
      font-size: 0.85em;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      color: var(--muted);
    }
    .body :global(table) { display: block; overflow-x: auto; }

    /* references section reads as data */
    .body :global(hr) {
      border: 0;
      border-top: 1px solid var(--line);
      margin: 2.5em 0;
    }

    /* References — single source for the visible list and schema citation */
    .refs { margin-top: 3rem; }
    .refs > h2 { padding-top: 0.4em; border-top: 1px solid var(--line); }
    .ref { font-size: var(--step--1); line-height: 1.55; margin: 0.85em 0; }
    .ref-n { color: var(--muted); margin-right: 0.2ch; }
    .ref-url { word-break: break-all; }
    .ref-note { margin-top: 1.5em; }

    /* Per-article glossary — definitions live on the article's own page */
    .article-glossary { margin-top: 3rem; }
    .article-glossary > h2 { padding-top: 0.4em; border-top: 1px solid var(--line); }
    .g-terms { margin: 0; }
    .g-term {
      border-top: 1px solid var(--line);
      padding: 0.9em 0;
      scroll-margin-top: 5rem;
    }
    .g-term:first-of-type { border-top: 0; }
    .g-term dt { display: flex; align-items: baseline; gap: 0.8ch; flex-wrap: wrap; }
    .g-head { font-weight: 650; }
    .g-name { font-size: var(--step--1); }
    .g-term dd { margin: 0.3em 0 0; font-size: var(--step--1); line-height: 1.55; }

    /* FAQ — atomic Q&A, citable by AI and search */
    .faq { margin-top: 3.5rem; }
    .faq > h2 { padding-top: 0.4em; border-top: 1px solid var(--line); }
    .faq-item { border-top: 1px solid var(--line); }
    .faq-item:first-of-type { border-top: 0; }
    .faq-q { font-size: var(--step-1); margin: 1.4em 0 0.3em; }
    .faq-a { margin: 0 0 1.4em; }
  </style>
</Base>
